---
import BaseFooter from '@/components/BaseFooter.astro';
import BaseHead from '@/components/BaseHead.astro';
import BaseHeader from '@/components/BaseHeader.astro';
import { InterfaceKit } from 'interface-kit/react';
import Themes from 'astro-themes';

import '../styles/global.css';

const { title, description, ...meta } = Astro.props;
const isDev = import.meta.env.DEV;
---

<html lang="en" class="h-full scroll-smooth">
  <head>
    <BaseHead {title} {description} {...meta} />
    <Themes />
  </head>
  <body
    class="bg-background text-foreground flex min-h-full w-full flex-col antialiased px-4 md:px-8"
  >
    <BaseHeader />
    <main role="main" class="flex-1">
      <slot />
    </main>
    <BaseFooter />
    {isDev && <InterfaceKit client:only="react" />}
    <script>
      document.addEventListener('click', (e) => {
        const button = (e.target as HTMLElement).closest('.code-copy');
        if (!button) return;

        const pre = button.closest('pre');
        if (!pre) return;

        const code = pre.querySelector('code');
        if (!code) return;

        const text = code.textContent?.replace(/\n$/, '') || '';

        navigator.clipboard.writeText(text).then(() => {
          button.classList.add('copied');
          setTimeout(() => button.classList.remove('copied'), 2000);
        });
      });
    </script>
  </body>
</html>
