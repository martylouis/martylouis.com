---
import ButtonLink from '@/components/ButtonLink.astro';
---

<section class="mb-20 flex flex-col gap-6 max-w-xl mx-auto w-full">
  <div class="space-y-2">
    <Image
      src={marty}
      alt="Marty Louis"
      width={128}
      loading="eager"
      class="ring-offset-background ring-border size-16 shrink-0 overflow-hidden rounded-full ring-1 ring-offset-1"
    />
    <h1 class="font-serif text-4xl tracking-tight text-balance">
      Hey, I'm Marty.
    </h1>
  </div>
  <p class="text-lg text-muted-foreground text-balance">
    I'm a designer and developer based on the Gulf Coast of Florida. I help
    small businesses and startups build websites that are simple, fast, and easy
    to maintain.
  </p>
  <div>
    <ButtonLink href="/contact/">Get in touch</ButtonLink>
  </div>
</section>
