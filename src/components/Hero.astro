---
import ButtonLink from '@/components/ButtonLink.astro';
---

<section
  class="mb-20 flex flex-col items-center gap-6 text-center max-w-xl mx-auto w-full"
>
  <h1 class="text-4xl tracking-tight text-balance">Hey, I'm Marty.</h1>
  <p class="text-lg text-muted-foreground text-balance">
    I'm a designer and developer based on the Gulf Coast of Florida. I help
    small businesses and startups build websites that are simple, fast, and easy
    to maintain.
  </p>
  <ButtonLink href="/contact/">Get in touch</ButtonLink>
</section>
